# NextAuth Configuration (Required for Login)
# run `npx auth secret` to generate
AUTH_SECRET="generate_a_random_string_here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Required for login and Google Drive storage)
# Obtain these from Google Cloud Console
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OpenAI API Key (Required for resume analysis)
OPENAI_API_KEY=""

# Optional: Domain Restriction
# ALLOWED_DOMAIN="yourdomain.com"
